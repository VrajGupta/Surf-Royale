; Engine configuration file.
; Godot 4.7.1 is pinned for the risk prototype.

config_version=5

[application]
config/name="Surf Royale Risk Slice"
run/main_scene="res://src/app/main.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")

[display]

[display/window]
size/viewport_width=1600
size/viewport_height=900
size/window_width_override=1280
size/window_height_override=720
stretch/mode="canvas_items"

[physics]
common/physics_ticks_per_second=30
common/max_physics_steps_per_frame=8

[rendering]
textures/vram_compression/import_etc2_astc=true
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0.035, 0.09, 0.13, 1)
